default_platform(:ios)

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  private_lane :asc_api_key do
    key_filepath = ENV["APP_STORE_CONNECT_KEY_FILEPATH"].to_s.empty? ? nil : ENV["APP_STORE_CONNECT_KEY_FILEPATH"]
    key_content = ENV["APP_STORE_CONNECT_KEY_CONTENT"].to_s.empty? ? nil : ENV["APP_STORE_CONNECT_KEY_CONTENT"]

    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: key_filepath,
      key_content: key_content,
    )
  end

  desc "Create or renew App Store signing certs/profiles via match (run this once, and again only when certs actually need to change)"
  lane :certs do
    match(type: "appstore", readonly: false, api_key: asc_api_key)
  end

  desc "Build the app and upload a new build to TestFlight"
  lane :beta do
    api_key = asc_api_key

    # app.json (+ config plugins) is the single source of truth for the
    # native iOS project here — ios/ is gitignored and fully regenerated
    # on every run, so this lane never depends on stale local native state.
    sh("cd .. && npx expo prebuild --platform ios --clean --no-install")
    sh("cd ../ios && pod install")

    match(type: "appstore", readonly: true, api_key: api_key)

    next_build_number = app_store_build_number(
      api_key: api_key,
      live: false,
      initial_build_number: 0,
    ) + 1
    increment_build_number(
      xcodeproj: "./ios/PluginApp.xcodeproj",
      build_number: next_build_number,
    )

    build_app(
      workspace: "./ios/PluginApp.xcworkspace",
      scheme: "PluginApp",
      export_method: "app-store",
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
