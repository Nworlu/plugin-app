# Copy this to fastlane/.env (gitignored) and fill in real values.
# fastlane auto-loads fastlane/.env — nothing else needs to source it.

# --- App Store Connect API key (App Store Connect > Users and Access > Keys) ---
# Only an Account Holder/Admin can generate this. Give it "App Manager" access.
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
# Either point at the downloaded .p8 file locally...
APP_STORE_CONNECT_KEY_FILEPATH=
# ...or, for CI, paste its base64-encoded contents instead (never commit the raw .p8):
# base64 -i AuthKey_XXXXXXXXXX.p8 | pbcopy
APP_STORE_CONNECT_KEY_CONTENT=

# --- Apple Developer team (developer.apple.com/account > Membership) ---
FASTLANE_TEAM_ID=
# Only needed if your App Store Connect team differs from your dev team.
ITC_TEAM_ID=

# --- match (fastlane's code-signing cert/profile storage) ---
# Create an empty *private* git repo for this first, e.g. github.com/you/plugin-app-certificates
MATCH_GIT_URL=
# Passphrase match uses to encrypt/decrypt everything in that repo. Pick a strong one and keep it safe — you'll need it on every machine/CI that runs these lanes.
MATCH_PASSWORD=
