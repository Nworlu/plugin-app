# Values come from env vars (fastlane auto-loads fastlane/.env, gitignored)
# so nothing here needs to change per developer/CI machine.
app_identifier(ENV["APP_IDENTIFIER"] || "com.pluginapp")
apple_id(ENV["APPLE_ID"]) if ENV["APPLE_ID"]
team_id(ENV["FASTLANE_TEAM_ID"]) if ENV["FASTLANE_TEAM_ID"]
itc_team_id(ENV["ITC_TEAM_ID"]) if ENV["ITC_TEAM_ID"]
